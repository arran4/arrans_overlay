--- .github/workflows/nightly-site-generate.yml
+++ .github/workflows/nightly-site-generate.yml
@@ -3,6 +3,9 @@
 on:
   schedule:
     - cron: '0 4 * * *'
   workflow_dispatch:
+  push:
+    paths:
+      - '.github/workflows/nightly-site-generate.yml'

 permissions:
   contents: read
@@ -14,13 +17,14 @@
       - name: Checkout repository
         uses: actions/checkout@v4

-      - name: Setup Go
-        uses: actions/setup-go@v5
-        with:
-          go-version: '1.26'
-
       - name: Install g2
-        run: go install github.com/arran4/g2/cmd/g2@latest
+        run: |
+          mkdir -p /tmp/g2-bin
+          curl -sL $(curl -s https://api.github.com/repos/arran4/g2/releases/latest | jq -r '.assets[] | select(.name | endswith("linux_amd64.tar.gz")) | .browser_download_url') | tar -xz -C /tmp/g2-bin

       - name: Generate site
-        run: ~/go/bin/g2 overlay site generate -out site_out
+        run: |
+          /tmp/g2-bin/g2 overlay site generate -out site_out
+          # Add generation date and time to the footer
+          find site_out -type f -name "*.html" -exec sed -i "s|</footer>|<br>Generated on $(date -u +'%Y-%m-%d %H:%M:%S UTC')</footer>|g" {} +

       - name: Upload artifact
         uses: actions/upload-pages-artifact@v3
